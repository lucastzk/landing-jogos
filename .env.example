# ============================================================================
#  AmploPay — credenciais do CHECKOUT (lado SERVIDOR)
# ============================================================================
#  Copie este arquivo para `.env` e preencha. O `.env` está no .gitignore e
#  NUNCA deve ir pro git nem pro navegador.
#
#  ⚠️ As chaves que você colou no chat estão QUEIMADAS. Gere chaves novas no
#     painel da AmploPay antes de usar. Para desenvolver, use as credenciais de
#     SANDBOX/TESTE, não as de produção.
# ============================================================================

# Chave pública da AmploPay (identifica a conta).
AMPLOPAY_PUBLIC_KEY=

# Chave secreta da AmploPay (assina as requisições). NUNCA exponha no front.
AMPLOPAY_SECRET_KEY=

# Base da API. Use a URL de sandbox enquanto testa; troque para produção depois.
# (Confirme a URL exata na documentação da AmploPay.)
AMPLOPAY_API_BASE=

# Segredo do webhook/postback (se a AmploPay assinar os callbacks). Opcional.
AMPLOPAY_WEBHOOK_SECRET=

# URL pública do site (usada para montar a postbackUrl do webhook).
# Em dev pode deixar http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----------------------------------------------------------------------------
#  Painel admin (/admin) — gerenciar conteúdo do site
# ----------------------------------------------------------------------------
# Senha do painel. OBRIGATÓRIA em produção: sem ela, o login é recusado (não
# existe senha padrão). Use uma senha FORTE.
ADMIN_PASSWORD=

# Segredo do servidor para o cookie de sessão do admin (HMAC). Sem ele o painel
# funciona, mas o cookie fica derivável da senha — DEFINA um valor aleatório:
#   openssl rand -hex 32
ADMIN_SESSION_SECRET=
